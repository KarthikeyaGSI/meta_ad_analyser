# Example environment variables for local development
# Frontend public variables (Next.js will expose these)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://tor.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=6a1542e40024cf4f2e4c
NEXT_PUBLIC_APPWRITE_DATABASE_ID=6a154386002ed0775f5e

# Backend secrets (do NOT commit this file, use .env.local)
APPWRITE_API_KEY=YOUR_APPWRITE_SERVER_KEY
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET
META_REDIRECT_URI=YOUR_META_REDIRECT_URI
JWT_SECRET=YOUR_JWT_SECRET

UPSTASH_REDIS_REST_URL=YOUR_UPSTASH_REDIS_URL
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REDIS_TOKEN
